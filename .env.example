# Use your Supabase Postgres connection string here.
# Example format:
# postgres://postgres.[project-ref]:[password]@[host]:5432/postgres?sslmode=require
SUPABASE_DB_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require

# Resend email delivery
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Trulo <contact@jointrulo.com>
ADMIN_NOTIFICATION_EMAIL=contact@jointrulo.com

# Public app URL for links in outbound emails
PUBLIC_APP_URL=https://your-app.vercel.app

# Internal sales login
SALES_LOGIN_EMAIL=contact@jointrulo.com
SALES_LOGIN_PASSWORD=change-this-password

# Cookie signing secret
SALES_SESSION_SECRET=replace-with-a-long-random-secret
