VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Use your Supabase Postgres session pooler connection string here.
# Example format:
# postgresql://postgres.[project-ref]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Resend email delivery
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Trulo <contact@jointrulo.com>
ADMIN_NOTIFICATION_EMAIL=contact@jointrulo.com

# Public app URL for links in outbound emails
PUBLIC_APP_URL=https://your-app.vercel.app

# Internal sales login
SALES_LOGIN_EMAIL=contact@jointrulo.com
SALES_LOGIN_PASSWORD=replace-with-a-strong-password

# Cookie signing secret
SALES_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
